{
  "gateway": {
    "mode": "local"
  },
  "models": {
    "default": "deepseek/deepseek-chat",
    "providers": {
      "deepseek": {
        "apiKey": "${DEEPSEEK_API_KEY}",
        "baseUrl": "https://api.deepseek.com",
        "models": ["deepseek-chat", "deepseek-reasoner"]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["tg:8166805746"],
      "streaming": "partial",
      "historyLimit": 50,
      "customCommands": [
        { "command": "structure", "description": "📁 عرض هيكل المشروع" },
        { "command": "memory", "description": "🧠 قراءة/كتابة الذاكرة" },
        { "command": "review", "description": "🔍 مراجعة كود" },
        { "command": "edit", "description": "✏️ تعديل ملف" },
        { "command": "status", "description": "📊 حالة البوت" }
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/root/.openclaw/workspace",
      "model": "deepseek/deepseek-chat",
      "maxTokens": 4000,
      "temperature": 0.3
    }
  },
  "scheduler": {
    "heartbeatIntervalMinutes": 30
  }
}
