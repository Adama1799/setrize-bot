{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace"
    }
  },
  "models": {
    "default": "deepseek/deepseek-chat",
    "providers": {
      "deepseek": {
        "apiKey": "${DEEPSEEK_API_KEY}",
        "baseUrl": "https://api.deepseek.com",
        "models": ["deepseek-chat", "deepseek-reasoner"]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["tg:8166805746"],
      "streaming": "partial",
      "historyLimit": 50
    }
  },
  "scheduler": {
    "heartbeatIntervalMinutes": 30
  }
}
